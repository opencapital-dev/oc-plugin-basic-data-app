{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "app",
  "name": "yfinance Data",
  "id": "yfinance-app",
  "backend": true,
  "executable": "gpx_yfinance-app",
  "opencapital": {
    "plugin_id": "yfinance-app",
    "platform_plugin": false,
    "logical_views": [
      { "name": "instruments_used_v", "source_table": "public.instruments_used" },
      { "name": "fx_pairs_used_v", "source_table": "public.fx_pairs_used" }
    ],
    "query_entities": [
      {
        "name": "classification",
        "table": "instrument_ticker_mapping",
        "scope": "portfolio_id",
        "scope_label": "portfolio",
        "time_col": "",
        "grain": ["instrument_id", "portfolio_id"],
        "labels": { "portfolio": "portfolio_id", "instrument": "instrument_id" },
        "columns": ["instrument_id", "portfolio_id", "sector", "subindustry"],
        "kinds": {
          "instrument_id": "string",
          "portfolio_id": "string",
          "sector": "string",
          "subindustry": "string"
        }
      }
    ]
  },
  "info": {
    "keywords": ["yfinance", "backfill", "ingestor"],
    "description": "Operator console for yFinance Data: map Yahoo tickers to instruments; see backfill + live status per row.",
    "author": {
      "name": "Portfolio management"
    },
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "screenshots": [],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "includes": [
    {
      "type": "page",
      "name": "Instruments",
      "path": "/a/%PLUGIN_ID%/instruments",
      "addToNav": true,
      "defaultNav": true,
      "icon": "chart-line"
    }
  ],
  "dependencies": {
    "grafanaDependency": ">=12.3.0",
    "plugins": []
  },
  "jsonData": {
    "pluginId": "",
    "controlPlaneUrl": "",
    "gatewayUrl": "",
    "otelExporterOtlpEndpoint": "",
    "pollIntervalSec": 15,
    "qps": 1.0,
    "burst": 3,
    "liveEnable": true,
    "backfillEnable": true
  },
  "secureJsonFields": ["platformToken"]
}
