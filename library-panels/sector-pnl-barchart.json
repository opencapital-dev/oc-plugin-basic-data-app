{
  "datasource": {
    "type": "core-datasource",
    "uid": "core-datasource"
  },
  "description": "Equity PnL aggregated by GICS sector. One bar per sector: total PnL (realized + unrealized, equity + forex). Sectors come from the yfinance plugin's classification data \u2014 anything without a sector tag falls into 'Unclassified'. Sectors with no current position are hidden.",
  "fieldConfig": {
    "defaults": {
      "decimals": 0,
      "unit": "locale",
      "color": {
        "mode": "thresholds"
      },
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "dark-red",
            "value": null
          },
          {
            "color": "transparent",
            "value": -0.0001
          },
          {
            "color": "transparent",
            "value": 0.0001
          },
          {
            "color": "dark-green",
            "value": 1
          }
        ]
      },
      "custom": {
        "axisPlacement": "auto",
        "axisLabel": "",
        "axisSoftMin": 0,
        "lineWidth": 1,
        "fillOpacity": 80,
        "gradientMode": "none",
        "hideFrom": {
          "tooltip": false,
          "viz": false,
          "legend": false
        }
      }
    },
    "overrides": [
      {
        "matcher": {
          "id": "byName",
          "options": "Current PnL"
        },
        "properties": [
          {
            "id": "color",
            "value": {
              "mode": "fixed",
              "fixedColor": "#3D85C6"
            }
          }
        ]
      }
    ]
  },
  "options": {
    "orientation": "horizontal",
    "xField": "Sector",
    "barWidth": 0.85,
    "groupWidth": 0.75,
    "showValue": "auto",
    "stacking": "none",
    "legend": {
      "displayMode": "list",
      "placement": "bottom",
      "showLegend": true,
      "calcs": []
    },
    "tooltip": {
      "mode": "multi",
      "sort": "desc"
    }
  },
  "targets": [
    {
      "refId": "A",
      "datasource": {
        "type": "core-datasource",
        "uid": "core-datasource"
      },
      "ref": "basic-data-app/sector_pnl"
    }
  ],
  "title": "Equity PnL by sector (${base_currency})",
  "type": "barchart"
}
